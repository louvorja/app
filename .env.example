# =============================================================
# LouvorJA — variáveis de ambiente
# Copie este arquivo para .env e preencha os valores reais.
# NUNCA commite o .env com valores reais no git.
# =============================================================

# ------------------------------------------------------------
# Modo da aplicação
# Valores: development | production
# Controla logs de debug (Dev.js) e comportamento da Shell.
# ------------------------------------------------------------
VITE_APP_MODE=development

# ------------------------------------------------------------
# URLs da API louvorja.com.br
# Em dev offline, aponte para o servidor local (npm run files):
#   VITE_URL_DATABASE=http://localhost:7070/database
#   VITE_URL_FILES=http://localhost:7070
# ------------------------------------------------------------
VITE_URL_DATABASE=https://api.louvorja.com.br/json_db
VITE_URL_FILES=https://api.louvorja.com.br/file

# ------------------------------------------------------------
# Token da API louvorja.com.br
# Necessário para o handshake FTP (download de coletâneas no desktop).
# Obtido com o administrador do sistema.
# ------------------------------------------------------------
VITE_API_TOKEN=

# ------------------------------------------------------------
# Versão exibida no módulo "Atualização" (update)
# Normalmente injetada pelo CI durante o build (ex: npm_package_version).
# Deixar vazio usa o fallback "—" no display.
# Exemplo: VITE_APP_VERSION=1.27.0
# ------------------------------------------------------------
# VITE_APP_VERSION=

# ------------------------------------------------------------
# Versão do banco de dados (invalida cache do Database.js)
# Quando alterada, o cache sessionStorage é descartado e os JSONs
# são re-buscados do servidor. Útil quando o banco é atualizado
# sem reiniciar o browser. Deixar vazio desativa invalidação por versão
# (cache expira apenas por TTL — 1 hora).
# Exemplo: VITE_DB_VERSION=20260101
# ------------------------------------------------------------
# VITE_DB_VERSION=

# ------------------------------------------------------------
# Target do build
# "desktop" → Electron (base "./", sem PWA/Service Worker)
# vazio     → web/PWA (padrão)
# Usado em vite.config.js para condicionar plugins e base URL.
# ------------------------------------------------------------
# VITE_TARGET=desktop

# ------------------------------------------------------------
# URL base para deploy em subpath (somente web/PWA)
# Necessário quando o app não está na raiz do domínio.
# Deve terminar com "/" — ex: /app/
# Deixar vazio para deploy na raiz "/".
# ------------------------------------------------------------
# VITE_BASE_URL=/

# ------------------------------------------------------------
# Percy — regressão visual (testes de snapshot)
# Obtenha o token em https://percy.io/ após criar o projeto "louvorja".
# Necessário apenas para rodar: npm run test:visual
# ------------------------------------------------------------
PERCY_TOKEN=

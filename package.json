{
  "name": "louvorja",
  "version": "1.27.0",
  "description": "Sistema de apresentação de letras de músicas e conteúdo bíblico para cultos e eventos religiosos.",
  "author": {
    "name": "LouvorJA",
    "email": "contato@louvorja.com.br",
    "url": "https://louvorja.com.br"
  },
  "private": true,
  "main": "electron/main.cjs",
  "scripts": {
    "version:major": "npm version major",
    "version:minor": "npm version minor",
    "version:patch": "npm version patch",
    "version:max": "npm version major",
    "version:min": "npm version minor",
    "version:bug": "npm version patch",
    "serve": "vite preview",
    "validate:manifests": "node scripts/validate-manifests.mjs",
    "typecheck": "tsc --noEmit",
    "prebuild": "npm run validate:manifests && npm run typecheck",
    "build": "vite build",
    "lint": "eslint .",
    "format": "prettier --write \"src/**/*.{vue,js,json}\"",
    "format:check": "prettier --check \"src/**/*.{vue,js,json}\"",
    "dev": "vite",
    "host": "vite --host",
    "files": "node node/server.js",
    "git:tag": "git tag -a -f v%npm_package_version% -m \"Versão %npm_package_version%\" && git push origin -f v%npm_package_version% && git push -u origin main",
    "electron:dev": "concurrently -k \"cross-env VITE_TARGET=desktop npm run dev\" \"wait-on http://localhost:5002 && cross-env ELECTRON_DEV=1 ELECTRON_RUN_AS_NODE= electron .\"",
    "electron:build": "cross-env VITE_TARGET=desktop npm run build && electron-builder",
    "electron:build:win": "cross-env VITE_TARGET=desktop npm run build && electron-builder --win",
    "electron:build:mac": "cross-env VITE_TARGET=desktop npm run build && electron-builder --mac",
    "electron:build:linux": "cross-env VITE_TARGET=desktop npm run build && electron-builder --linux",
    "electron:start": "electron .",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:ui": "vitest --ui",
    "test:e2e": "playwright test",
    "test:visual": "percy exec -- playwright test e2e/visual.spec.js",
    "coverage": "vitest run --coverage",
    "prepare": "husky",
    "type-check": "vue-tsc --noEmit"
  },
  "dependencies": {
    "@mdi/font": "^7.4.47",
    "basic-ftp": "^5.0.5",
    "electron-updater": "^6.8.3",
    "express": "^4.22.1",
    "fs-extra": "^11.2.0",
    "fuse.js": "^7.3.0",
    "idb": "^8.0.3",
    "jszip": "^3.10.1",
    "pinia": "^3.0.4",
    "vue": "~3.5.29",
    "vue-country-flag-next": "^2.3.2",
    "vue-fullscreen": "^3.1.3",
    "vue-i18n": "^11.2.8",
    "vue-json-pretty": "^2.4.0",
    "vue-router": "5.0.6",
    "vuedraggable": "^4.1.0",
    "vuetify": "~4.0.6",
    "webfontloader": "^1.0.0"
  },
  "devDependencies": {
    "@percy/cli": "^1.31.13",
    "@percy/playwright": "^1.1.0",
    "@playwright/test": "^1.59.1",
    "@types/node": "^25.6.0",
    "@vitejs/plugin-vue": "^6.0.4",
    "@vitest/coverage-v8": "^4.1.5",
    "@vitest/ui": "^4.1.5",
    "axe-core": "^4.11.4",
    "concurrently": "^9.2.1",
    "cross-env": "^10.1.0",
    "electron": "^41.4.0",
    "electron-builder": "^26.8.1",
    "eslint": "^9.39.3",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-vue": "^9.33.0",
    "husky": "^9.1.7",
    "jsdom": "^29.1.1",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.3",
    "rollup-plugin-visualizer": "^7.0.1",
    "sass": "^1.83.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.2",
    "vite": "^7.3.1",
    "vite-plugin-pwa": "^1.2.0",
    "vite-plugin-vuetify": "^2.1.3",
    "vitest": "^4.1.5",
    "vue-axe": "^2.4.4",
    "vue-tsc": "^3.2.8",
    "wait-on": "^9.0.5"
  },
  "eslintConfig": {
    "root": true,
    "env": {
      "node": true
    },
    "extends": [
      "plugin:vue/vue3-essential",
      "eslint:recommended"
    ],
    "rules": {}
  },
  "lint-staged": {
    "*.{vue,js}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,css,scss}": [
      "prettier --write"
    ]
  }
}
